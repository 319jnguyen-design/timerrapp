---
layout: base.njk
title: "Online Clock — Free Digital Clock | Timerrapp"
description: "Free online clock showing the exact time. Also includes alarm clock, timer, stopwatch and Pomodoro timer. No download needed."
activePage: clock
---

<div id="skyicon" style="margin-bottom:1rem;display:flex;justify-content:center;"></div>

<div style="font-family:'DM Mono',monospace;font-size:clamp(4rem,14vw,8rem);font-weight:300;letter-spacing:-0.03em;line-height:1;" id="clockTime">00:00:00</div>
<div style="font-family:'DM Mono',monospace;font-size:1.3rem;color:var(--accent);margin-top:0.4rem;letter-spacing:0.15em;" id="clockAmPm">AM</div>
<div style="font-size:0.9rem;color:var(--muted);margin-top:1.5rem;letter-spacing:0.06em;text-transform:uppercase;" id="clockDate"></div>
<div style="font-size:0.78rem;color:var(--hint);margin-top:0.3rem;" id="clockTZ"></div>

<hr class="divider" style="margin-top:3rem;">

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-top:2rem;">

  <a href="/alarm/" style="display:block;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:1.4rem 1rem;text-decoration:none;text-align:center;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border2)'">
    <div style="display:flex;justify-content:center;margin-bottom:10px;">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="14" cy="15" r="9"/><polyline points="14,10 14,15 17,18"/>
        <line x1="10" y1="3" x2="7" y2="6"/><line x1="18" y1="3" x2="21" y2="6"/>
      </svg>
    </div>
    <div style="font-weight:500;color:var(--text);font-size:0.9rem;">Alarm Clock</div>
    <div style="font-size:0.75rem;color:var(--muted);margin-top:3px;">Set a wake-up alarm</div>
  </a>

  <a href="/timer/" style="display:block;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:1.4rem 1rem;text-decoration:none;text-align:center;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border2)'">
    <div style="display:flex;justify-content:center;margin-bottom:10px;">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="14" cy="16" r="9"/><polyline points="14,11 14,16 18,18"/>
        <line x1="11" y1="3" x2="17" y2="3"/><line x1="14" y1="3" x2="14" y2="7"/>
      </svg>
    </div>
    <div style="font-weight:500;color:var(--text);font-size:0.9rem;">Timer</div>
    <div style="font-size:0.75rem;color:var(--muted);margin-top:3px;">Countdown timer</div>
  </a>

  <a href="/stopwatch/" style="display:block;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:1.4rem 1rem;text-decoration:none;text-align:center;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border2)'">
    <div style="display:flex;justify-content:center;margin-bottom:10px;">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="14" cy="16" r="9"/><polyline points="14,11 14,16"/>
        <line x1="11" y1="3" x2="17" y2="3"/><line x1="22" y1="8" x2="24" y2="6"/>
      </svg>
    </div>
    <div style="font-weight:500;color:var(--text);font-size:0.9rem;">Stopwatch</div>
    <div style="font-size:0.75rem;color:var(--muted);margin-top:3px;">Track elapsed time</div>
  </a>

  <a href="/pomodoro/" style="display:block;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:1.4rem 1rem;text-decoration:none;text-align:center;transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border2)'">
    <div style="display:flex;justify-content:center;margin-bottom:10px;">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="14" cy="14" r="9"/>
        <path d="M14 5 Q18 9 14 14 Q10 9 14 5Z" fill="#c8a96e" stroke="none"/>
        <line x1="14" y1="14" x2="14" y2="19"/><line x1="11" y1="22" x2="17" y2="22"/>
      </svg>
    </div>
    <div style="font-weight:500;color:var(--text);font-size:0.9rem;">Pomodoro</div>
    <div style="font-size:0.75rem;color:var(--muted);margin-top:3px;">Focus timer</div>
  </a>

</div>

<script>
function drawSun(el) {
  el.innerHTML = `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="18" cy="18" r="6" stroke="#c8a96e" stroke-width="1.5"/>
    <line x1="18" y1="4" x2="18" y2="8" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="18" y1="28" x2="18" y2="32" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="4" y1="18" x2="8" y2="18" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="28" y1="18" x2="32" y2="18" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="8.1" y1="8.1" x2="10.9" y2="10.9" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="25.1" y1="25.1" x2="27.9" y2="27.9" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="27.9" y1="8.1" x2="25.1" y2="10.9" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="10.9" y1="25.1" x2="8.1" y2="27.9" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`;
}
function drawMoon(el) {
  el.innerHTML = `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M26 24a12 12 0 1 1-10-20 10 10 0 0 0 10 20z" stroke="rgba(240,237,232,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`;
}
function updateClock() {
  const now = new Date();
  const h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12 = h % 12 || 12;
  document.getElementById('clockTime').textContent =
    String(h12).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  document.getElementById('clockAmPm').textContent = ampm;
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('clockDate').textContent =
    days[now.getDay()]+', '+months[now.getMonth()]+' '+now.getDate()+', '+now.getFullYear();
  document.getElementById('clockTZ').textContent =
    Intl.DateTimeFormat().resolvedOptions().timeZone;
  const icon = document.getElementById('skyicon');
  if (h >= 6 && h < 20) drawSun(icon); else drawMoon(icon);
}
setInterval(updateClock, 1000);
updateClock();
</script>