---
layout: base.njk
title: "Pomodoro Timer — Free Online Pomodoro Clock | Timerrapp"
description: "Free online Pomodoro timer. 25 minute focus sessions with 5 minute breaks. Boost your productivity with the Pomodoro technique."
activePage: pomodoro
---

<h1 class="page-title">Pomodoro Timer</h1>
<p class="page-subtitle">25 minutes of focus. 5 minute break. Repeat.</p>

<div style="display:flex;gap:8px;justify-content:center;margin-bottom:2rem;">
  <button onclick="setMode('focus')" id="btnFocus" class="btn btn-primary" style="padding:6px 20px;font-size:0.85rem;">Focus</button>
  <button onclick="setMode('short')" id="btnShort" class="btn btn-secondary" style="padding:6px 20px;font-size:0.85rem;">Short Break</button>
  <button onclick="setMode('long')" id="btnLong" class="btn btn-secondary" style="padding:6px 20px;font-size:0.85rem;">Long Break</button>
</div>

<div style="position:relative;display:inline-block;margin-bottom:1rem;">
  <svg width="220" height="220" viewBox="0 0 220 220">
    <circle cx="110" cy="110" r="96" fill="none" stroke="var(--surface2)" stroke-width="6"/>
    <circle id="pomRing" cx="110" cy="110" r="96" fill="none" stroke="var(--accent)"
      stroke-width="6" stroke-linecap="round"
      stroke-dasharray="603.2" stroke-dashoffset="0"
      transform="rotate(-90 110 110)"
      style="transition:stroke-dashoffset 1s linear,stroke 0.4s;"/>
    <circle id="pomDot" cx="110" cy="14" r="5" fill="var(--accent)" style="transition:fill 0.4s;"/>
  </svg>
  <div style="position:absolute;top:0;left:0;width:220px;height:220px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;">
    <div style="font-family:var(--font-mono);font-size:2.8rem;font-weight:300;letter-spacing:-0.02em;" id="pomDisplay">25:00</div>
    <div style="font-size:0.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;font-family:var(--font-body);" id="pomMode">Focus Time</div>
  </div>
</div>

<div style="font-size:0.85rem;color:var(--muted);margin-bottom:1.5rem;font-family:var(--font-body);">
  Session <span id="pomSession" style="color:var(--accent);font-family:var(--font-mono);">1</span> of 4
</div>

<div class="sound-row">
  <label>Sound</label>
  <select id="pomSound" class="sound-select">
    <option value="chime" selected>Chime</option>
    <option value="bells">Bells</option>
    <option value="beep">Beep</option>
    <option value="digital">Digital</option>
    <option value="alarm">Alarm</option>
  </select>
  <button class="btn-test" onclick="playSound(document.getElementById('pomSound').value)">▶ Test</button>
</div>

<div class="controls">
  <button class="btn btn-primary" id="pomStartBtn" onclick="togglePom()">Start</button>
  <button class="btn btn-secondary" onclick="resetPom()">Reset</button>
  <button class="btn btn-secondary" onclick="skipPom()">Skip</button>
</div>
<div class="desktop-only" style="margin-top:0.75rem;font-size:0.75rem;color:var(--hint);">Press <kbd style="background:var(--surface2);border:1px solid var(--border2);border-radius:4px;padding:1px 6px;font-family:var(--font-mono);font-size:0.72rem;">Space</kbd> to start or pause</div>

<hr class="divider">

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:2rem;">
  <div class="glass" style="padding:1rem;">
    <div style="font-size:0.7rem;color:var(--hint);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;font-family:var(--font-body);">Completed</div>
    <div style="font-family:var(--font-mono);font-size:1.8rem;font-weight:300;color:var(--accent);" id="statCompleted">0</div>
  </div>
  <div class="glass" style="padding:1rem;">
    <div style="font-size:0.7rem;color:var(--hint);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;font-family:var(--font-body);">Focus time</div>
    <div style="font-family:var(--font-mono);font-size:1.8rem;font-weight:300;color:var(--accent);" id="statTime">0m</div>
  </div>
  <div class="glass" style="padding:1rem;">
    <div style="font-size:0.7rem;color:var(--hint);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;font-family:var(--font-body);">Streak</div>
    <div style="font-family:var(--font-mono);font-size:1.8rem;font-weight:300;color:var(--accent);" id="statStreak">0</div>
  </div>
</div>

<!-- Session history log -->
<div id="sessionLogWrap" style="display:none;margin-bottom:2rem;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
    <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--hint);font-family:var(--font-body);">Today's sessions</div>
    <button onclick="clearHistory()" style="font-size:0.72rem;color:var(--muted);background:none;border:none;cursor:pointer;font-family:var(--font-body);padding:0;">Clear history</button>
  </div>
  <div id="sessionLog" style="display:flex;flex-direction:column;gap:6px;max-height:200px;overflow-y:auto;"></div>
</div>

<div class="glass" style="padding:1.5rem;text-align:left;">
  <div style="font-family:var(--font-heading);font-size:1.2rem;margin-bottom:0.75rem;">What is the Pomodoro Technique?</div>
  <p style="color:var(--muted);font-size:0.88rem;line-height:1.7;margin-bottom:0.75rem;font-family:var(--font-body);">Developed by Francesco Cirillo, the Pomodoro Technique breaks work into 25-minute focused intervals separated by short 5-minute breaks.</p>
  <p style="color:var(--muted);font-size:0.88rem;line-height:1.7;font-family:var(--font-body);">After 4 sessions, take a longer 15-minute break. This trains your brain to focus deeply and helps you understand how long tasks actually take.</p>
</div>

<script>
const CIRC = 603.2;
const MODES = {
  focus: { label:'Focus Time', secs:25*60, color:'var(--accent)' },
  short: { label:'Short Break', secs:5*60, color:'var(--success)' },
  long:  { label:'Long Break',  secs:15*60, color:'#7b68ee' }
};
let currentMode = 'focus';
let total = MODES.focus.secs;
let remaining = total;
let running = false;
let iv = null;
let session = 1;

// --- localStorage persistence ---
const today = new Date().toDateString();
const raw = JSON.parse(localStorage.getItem('pom_stats') || '{}');

// Reset streak if last session wasn't yesterday or today
let lastSession = raw.lastSession || null;
let streak = raw.streak || 0;
if (lastSession && lastSession !== today) {
  const yesterday = new Date(Date.now() - 86400000).toDateString();
  if (lastSession !== yesterday) streak = 0;
}

let completed = raw.completed || 0;
let totalFocusSeconds = raw.totalFocusSeconds || 0;

// Session history log (max 30, today only)
let sessionHistory = JSON.parse(localStorage.getItem('pom_history') || '[]');
// Filter to today only
sessionHistory = sessionHistory.filter(s => s.date === today);

function saveStats() {
  lastSession = today;
  localStorage.setItem('pom_stats', JSON.stringify({ completed, totalFocusSeconds, streak, lastSession }));
}

function saveHistory(entry) {
  sessionHistory.unshift(entry);
  if (sessionHistory.length > 30) sessionHistory = sessionHistory.slice(0, 30);
  localStorage.setItem('pom_history', JSON.stringify(sessionHistory));
}

function clearHistory() {
  sessionHistory = [];
  localStorage.removeItem('pom_history');
  renderSessionLog();
}

function renderSessionLog() {
  const wrap = document.getElementById('sessionLogWrap');
  const log = document.getElementById('sessionLog');
  if (!sessionHistory.length) { wrap.style.display = 'none'; return; }
  wrap.style.display = 'block';
  log.innerHTML = sessionHistory.map(s => `
    <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--surface);border:1px solid var(--border);border-radius:8px;">
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="font-size:0.75rem;">${s.type === 'focus' ? '🍅' : '☕'}</span>
        <span style="font-size:0.82rem;color:var(--text);font-family:var(--font-body);">${s.label}</span>
      </div>
      <span style="font-family:var(--font-mono);font-size:0.78rem;color:var(--muted);">${s.time}</span>
    </div>`).join('');
}

function setMode(mode) {
  resetPom();
  currentMode = mode;
  total = MODES[mode].secs;
  remaining = total;
  document.getElementById('pomMode').textContent = MODES[mode].label;
  document.getElementById('pomRing').style.stroke = MODES[mode].color;
  document.getElementById('pomDot').style.fill = MODES[mode].color;
  updateDisplay(remaining);
  ['focus','short','long'].forEach(m => {
    const id = 'btn'+m.charAt(0).toUpperCase()+m.slice(1);
    const btn = document.getElementById(id);
    btn.className = m === mode ? 'btn btn-primary' : 'btn btn-secondary';
    btn.style.padding = '6px 20px';
    btn.style.fontSize = '0.85rem';
  });
}

function updateDisplay(secs) {
  const m = Math.floor(secs/60), s = secs%60;
  document.getElementById('pomDisplay').textContent = String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  const pct = total > 0 ? secs/total : 1;
  const offset = CIRC*(1-pct);
  document.getElementById('pomRing').style.strokeDashoffset = offset;
  const angle = (1-pct)*360-90;
  const rad = angle*Math.PI/180;
  document.getElementById('pomDot').setAttribute('cx',(110+96*Math.cos(rad)).toFixed(2));
  document.getElementById('pomDot').setAttribute('cy',(110+96*Math.sin(rad)).toFixed(2));
}

function togglePom() {
  if (!running) {
    running = true;
    document.getElementById('pomStartBtn').textContent = 'Pause';
    iv = setInterval(() => {
      remaining--;
      if (currentMode === 'focus') totalFocusSeconds++;
      updateDisplay(remaining);
      updateStats();
      if (remaining <= 0) {
        running = false; clearInterval(iv);
        document.getElementById('pomStartBtn').textContent = 'Start';
        playSound(document.getElementById('pomSound').value);
        const now = new Date();
        const timeStr = now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
        if (currentMode === 'focus') {
          completed++; streak++;
          session = session >= 4 ? 1 : session+1;
          document.getElementById('pomSession').textContent = session;
          saveHistory({ type: 'focus', label: 'Focus session', time: timeStr, date: today });
          saveStats();
          updateStats();
          renderSessionLog();
          setMode(session === 1 ? 'long' : 'short');
        } else {
          const breakLabel = currentMode === 'short' ? 'Short break' : 'Long break';
          saveHistory({ type: 'break', label: breakLabel, time: timeStr, date: today });
          renderSessionLog();
          setMode('focus');
        }
      }
    }, 1000);
  } else {
    running = false; clearInterval(iv);
    document.getElementById('pomStartBtn').textContent = 'Resume';
  }
}

function resetPom() {
  running = false; clearInterval(iv);
  remaining = total;
  document.getElementById('pomStartBtn').textContent = 'Start';
  document.getElementById('pomRing').style.strokeDashoffset = 0;
  document.getElementById('pomDot').setAttribute('cx','110');
  document.getElementById('pomDot').setAttribute('cy','14');
  updateDisplay(remaining);
}

function skipPom() {
  running = false; clearInterval(iv);
  remaining = 0; updateDisplay(0);
  if (currentMode === 'focus') {
    session = session >= 4 ? 1 : session+1;
    document.getElementById('pomSession').textContent = session;
    setMode(session === 1 ? 'long' : 'short');
  } else { setMode('focus'); }
}

function updateStats() {
  document.getElementById('statCompleted').textContent = completed;
  const mins = Math.floor(totalFocusSeconds/60);
  document.getElementById('statTime').textContent = mins >= 60 ? Math.floor(mins/60)+'h '+(mins%60)+'m' : mins+'m';
  document.getElementById('statStreak').textContent = streak;
}

function updateTabTitle() {
  if (running && remaining > 0) {
    const m = Math.floor(remaining/60), s = remaining%60;
    document.title = String(m).padStart(2,'0')+':'+String(s).padStart(2,'0')+' – Timerrapp';
  } else {
    document.title = 'Pomodoro Timer — Free Online Pomodoro Clock | Timerrapp';
  }
}

// Initialize
updateStats();
renderSessionLog();
setInterval(updateTabTitle, 1000);

document.addEventListener('keydown', function(e) {
  if (e.code !== 'Space') return;
  const tag = document.activeElement.tagName.toLowerCase();
  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
  e.preventDefault();
  togglePom();
});
</script>
