---
layout: base.njk
pagination:
  data: alarms
  size: 1
  alias: alarm
permalink: /alarm/{{ alarm.slug }}/
eleventyComputed:
  title: "Set Alarm for {{ alarm.time }} — Online Alarm Clock | Timerrapp"
  description: "Set a free online alarm for {{ alarm.time }}. Works in your browser, no download needed. Your alarm will ring right on this page."
activePage: alarm
---

<h1 style="font-family:var(--font-heading);font-size:2.5rem;font-weight:400;margin-bottom:0.5rem;">Set Alarm for {{ alarm.time }}</h1>
<p style="color:var(--muted);margin-bottom:2.5rem;font-family:var(--font-body);">Your browser will alert you at {{ alarm.time }}. Keep this tab open.</p>

<div style="text-align:center;padding:2rem 0;">
  <div style="font-family:var(--font-mono);font-size:clamp(3rem,10vw,6rem);font-weight:300;letter-spacing:-0.02em;" id="countdown">--:--:--</div>
  <div style="color:var(--muted);font-size:0.9rem;margin-top:1rem;font-family:var(--font-body);" id="status">Alarm set for {{ alarm.time }}</div>
  <div style="margin-top:2rem;display:flex;gap:10px;justify-content:center;">
    <button onclick="startAlarm()" id="startBtn" class="btn btn-primary">Activate Alarm</button>
    <button onclick="cancelAlarm()" class="btn btn-secondary">Cancel</button>
  </div>
</div>

<div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);">
  <h2 style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:1rem;font-weight:400;font-family:var(--font-body);">Other alarm times</h2>
  <div style="display:flex;flex-wrap:wrap;gap:8px;">
    {% for a in alarms %}
    {% if a.slug != alarm.slug %}
    <a href="/alarm/{{ a.slug }}/" class="chip" style="text-decoration:none;">{{ a.time }}</a>
    {% endif %}
    {% endfor %}
  </div>
</div>

<script>
const ALARM_H = {{ alarm.h }};
const ALARM_M = {{ alarm.m }};
let active = false;
let ringInterval = null;

function startAlarm() {
  active = true;
  document.getElementById('startBtn').textContent = 'Alarm Active ✓';
  document.getElementById('startBtn').style.opacity = '0.6';
  document.getElementById('startBtn').style.cursor = 'default';
  tick();
}

function cancelAlarm() {
  active = false;
  clearInterval(ringInterval);
  document.getElementById('status').textContent = 'Alarm cancelled.';
  document.getElementById('countdown').textContent = '--:--:--';
  document.getElementById('startBtn').textContent = 'Activate Alarm';
  document.getElementById('startBtn').style.opacity = '1';
  document.getElementById('startBtn').style.cursor = 'pointer';
}

function tick() {
  if (!active) return;
  const now = new Date();
  let target = new Date();
  target.setHours(ALARM_H, ALARM_M, 0, 0);
  if (target <= now) target.setDate(target.getDate()+1);
  const diff = target - now;
  const h = Math.floor(diff/3600000);
  const m = Math.floor((diff%3600000)/60000);
  const s = Math.floor((diff%60000)/1000);
  document.getElementById('countdown').textContent =
    String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  document.getElementById('status').textContent = 'Time until alarm fires';
  if (h===0 && m===0 && s===0) { fireAlarm(); return; }
  setTimeout(tick, 1000);
}

function fireAlarm() {
  document.getElementById('status').textContent = '🔔 Alarm ringing!';
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    function beep() {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value = 880; o.type = 'sine';
      g.gain.setValueAtTime(0.3,ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+0.5);
      o.start(ctx.currentTime); o.stop(ctx.currentTime+0.5);
    }
    beep();
    ringInterval = setInterval(beep, 1000);
    setTimeout(() => clearInterval(ringInterval), 30000);
  } catch(e) {}
}
</script>
