---
layout: base.njk
pagination:
  data: timers
  size: 1
  alias: timer
permalink: /timer/{{ timer.slug }}/
eleventyComputed:
  title: "{{ timer.duration }} Timer — Free Online Countdown | Timerrapp"
  description: "Free online {{ timer.duration }} timer. Starts instantly in your browser. No download needed — just click Start."
activePage: timer
---

<h1 style="font-family:'Instrument Serif',serif; font-size:2.5rem; font-weight:400; margin-bottom:0.5rem;">{{ timer.duration }} Timer</h1>
<p style="color:var(--muted); margin-bottom:2.5rem;">A free online {{ timer.duration }} countdown timer. Click Start and keep this tab open.</p>

<div style="text-align:center; padding:2rem 0;">
  <div style="position:relative; display:inline-block;">
    <svg width="200" height="200" viewBox="0 0 200 200" style="transform:rotate(-90deg)">
      <circle fill="none" stroke="var(--surface2)" stroke-width="4" cx="100" cy="100" r="92"/>
      <circle fill="none" stroke="var(--accent)" stroke-width="4" stroke-linecap="round"
        cx="100" cy="100" r="92" stroke-dasharray="578.1" stroke-dashoffset="0"
        id="timerRing" style="transition:stroke-dashoffset 1s linear, stroke 0.3s;"/>
    </svg>
    <div style="position:absolute; top:0; left:0; width:200px; height:200px; display:flex; align-items:center; justify-content:center;">
      <div style="font-family:'DM Mono',monospace; font-size:2.2rem; font-weight:300;" id="timerDisplay">{{ timer.duration }}</div>
    </div>
  </div>
  <div style="margin-top:2rem; display:flex; gap:10px; justify-content:center;">
    <button onclick="toggleTimer()" id="startBtn" style="padding:0.7rem 1.8rem; border-radius:10px; border:none; background:var(--accent); color:#0a0a0f; font-weight:500; cursor:pointer; font-family:'DM Sans',sans-serif;">Start</button>
    <button onclick="resetTimer()" style="padding:0.7rem 1.4rem; border-radius:10px; border:1px solid var(--border2); background:transparent; color:var(--text); cursor:pointer; font-family:'DM Sans',sans-serif;">Reset</button>
  </div>
</div>

<div style="margin-top:3rem; padding-top:2rem; border-top:1px solid var(--border);">
  <h2 style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--muted); margin-bottom:1rem; font-weight:400;">Other timers</h2>
  <div style="display:flex; flex-wrap:wrap; gap:8px;">
    {% for t in timers %}
    {% if t.slug != timer.slug %}
    <a href="/timer/{{ t.slug }}/" style="background:var(--surface); border:1px solid var(--border); border-radius:100px; padding:5px 14px; font-size:0.82rem; color:var(--muted); text-decoration:none; font-family:'DM Mono',monospace;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">{{ t.duration }}</a>
    {% endif %}
    {% endfor %}
  </div>
</div>

<script>
const TOTAL = {{ timer.seconds }};
const CIRC = 578.1;
let remaining = TOTAL, running = false, interval = null;

function toggleTimer() {
  if (!running) {
    running = true;
    document.getElementById('startBtn').textContent = 'Pause';
    interval = setInterval(() => {
      remaining--;
      updateDisplay(remaining);
      if (remaining <= 0) {
        running = false; clearInterval(interval);
        document.getElementById('startBtn').textContent = 'Start';
        fireAlarm();
      }
    }, 1000);
  } else {
    running = false; clearInterval(interval);
    document.getElementById('startBtn').textContent = 'Resume';
  }
}

function resetTimer() {
  running = false; clearInterval(interval);
  remaining = TOTAL;
  document.getElementById('startBtn').textContent = 'Start';
  document.getElementById('timerDisplay').textContent = '{{ timer.duration }}';
  document.getElementById('timerRing').style.strokeDashoffset = 0;
  document.getElementById('timerRing').style.stroke = 'var(--accent)';
}

function updateDisplay(secs) {
  const h = Math.floor(secs/3600);
  const m = Math.floor((secs%3600)/60);
  const s = secs%60;
  document.getElementById('timerDisplay').textContent =
    (h > 0 ? String(h).padStart(2,'0')+':' : '') +
    String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  document.getElementById('timerRing').style.strokeDashoffset = CIRC * (1 - secs/TOTAL);
  document.getElementById('timerRing').style.stroke = secs <= 10 ? '#e05c5c' : 'var(--accent)';
}

function fireAlarm() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    function beep() {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value = 880; o.type = 'sine';
      g.gain.setValueAtTime(0.3, ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);
      o.start(ctx.currentTime); o.stop(ctx.currentTime + 0.5);
    }
    beep(); let c = 0;
    const i = setInterval(() => { if(++c >= 5) clearInterval(i); else beep(); }, 1000);
  } catch(e) {}
}
</script>