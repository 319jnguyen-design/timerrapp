---
layout: base.njk
title: "Online Timer — Free Countdown Timer | Timerrapp"
description: "Free online countdown timer. Set a timer for any duration and get alerted in your browser. No download needed."
activePage: timer
---

<h1 class="page-title">Online Timer</h1>
<p class="page-subtitle">Set a countdown for any duration.</p>

<div style="position:relative;display:inline-block;margin-bottom:1.5rem;">
  <svg width="220" height="220" viewBox="0 0 220 220">
    <circle cx="110" cy="110" r="96" fill="none" stroke="var(--surface2)" stroke-width="6"/>
    <circle id="timerRing" cx="110" cy="110" r="96" fill="none" stroke="var(--accent)"
      stroke-width="6" stroke-linecap="round"
      stroke-dasharray="603.2" stroke-dashoffset="0"
      transform="rotate(-90 110 110)"
      style="transition:stroke-dashoffset 1s linear,stroke 0.4s;"/>
    <circle id="timerDot" cx="110" cy="14" r="5" fill="var(--accent)" style="transition:fill 0.4s;"/>
  </svg>
  <div style="position:absolute;top:0;left:0;width:220px;height:220px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;">
    <div style="font-family:'DM Mono',monospace;font-size:2.6rem;font-weight:300;letter-spacing:-0.02em;" id="timerDisplay">00:00</div>
    <div style="font-size:0.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;" id="timerStatus">Ready</div>
  </div>
</div>

<div class="chips">
  <div class="chip" onclick="setTimer(60)">1 min</div>
  <div class="chip" onclick="setTimer(300)">5 min</div>
  <div class="chip" onclick="setTimer(600)">10 min</div>
  <div class="chip" onclick="setTimer(900)">15 min</div>
  <div class="chip" onclick="setTimer(1500)">25 min</div>
  <div class="chip" onclick="setTimer(1800)">30 min</div>
  <div class="chip" onclick="setTimer(3600)">1 hr</div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1rem;">
  <div>
    <label class="field-label">Hours</label>
    <input type="number" id="timerH" min="0" max="99" value="0" class="input-field" style="font-size:1.4rem;">
  </div>
  <div>
    <label class="field-label">Minutes</label>
    <input type="number" id="timerM" min="0" max="59" value="5" class="input-field" style="font-size:1.4rem;">
  </div>
  <div>
    <label class="field-label">Seconds</label>
    <input type="number" id="timerS" min="0" max="59" value="0" class="input-field" style="font-size:1.4rem;">
  </div>
</div>

<div class="sound-row">
  <label>Sound</label>
  <select id="timerSound" class="sound-select">
    <option value="chime">Chime</option>
    <option value="bells">Bells</option>
    <option value="beep" selected>Beep</option>
    <option value="digital">Digital</option>
    <option value="alarm">Alarm</option>
  </select>
  <button class="btn-test" onclick="playSound(document.getElementById('timerSound').value)">▶ Test</button>
</div>

<div class="controls">
  <button class="btn btn-primary" id="timerStartBtn" onclick="toggleTimer()">Start</button>
  <button class="btn btn-secondary" onclick="resetTimer()">Reset</button>
</div>
<div style="margin-top:1rem;font-size:0.75rem;color:var(--hint);">Press <kbd style="background:var(--surface2);border:1px solid var(--border2);border-radius:4px;padding:1px 6px;font-family:'DM Mono',monospace;font-size:0.72rem;">Space</kbd> to start or pause</div>

<script>
const CIRC = 603.2;
let total = 0, remaining = 0, running = false, iv = null;

function setTimer(secs) {
  resetTimer();
  document.getElementById('timerH').value = Math.floor(secs/3600);
  document.getElementById('timerM').value = Math.floor((secs%3600)/60);
  document.getElementById('timerS').value = secs%60;
}

function getInput() {
  return (parseInt(document.getElementById('timerH').value)||0)*3600
       + (parseInt(document.getElementById('timerM').value)||0)*60
       + (parseInt(document.getElementById('timerS').value)||0);
}

function fmt(secs) {
  const h = Math.floor(secs/3600);
  const m = Math.floor((secs%3600)/60);
  const s = secs%60;
  if (h > 0) return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  return String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
}

function updateRing(secs) {
  const pct = total > 0 ? secs/total : 1;
  const offset = CIRC*(1-pct);
  const isLow = secs <= 10 && secs > 0;
  const color = isLow ? 'var(--danger)' : 'var(--accent)';
  document.getElementById('timerRing').style.strokeDashoffset = offset;
  document.getElementById('timerRing').style.stroke = color;
  document.getElementById('timerDot').style.fill = color;
  document.getElementById('timerDisplay').style.color = isLow ? 'var(--danger)' : 'var(--text)';
  const angle = (1-pct)*360 - 90;
  const rad = angle*Math.PI/180;
  document.getElementById('timerDot').setAttribute('cx', (110+96*Math.cos(rad)).toFixed(2));
  document.getElementById('timerDot').setAttribute('cy', (110+96*Math.sin(rad)).toFixed(2));
  document.getElementById('timerDisplay').textContent = fmt(secs);
}

function toggleTimer() {
  if (!running) {
    if (remaining === 0) { total = getInput(); remaining = total; }
    if (remaining <= 0) return;
    running = true;
    document.getElementById('timerStartBtn').textContent = 'Pause';
    document.getElementById('timerStatus').textContent = 'Counting down';
    iv = setInterval(() => {
      remaining--;
      updateRing(remaining);
      if (remaining <= 0) {
        running = false; clearInterval(iv);
        document.getElementById('timerStartBtn').textContent = 'Start';
        document.getElementById('timerStatus').textContent = 'Done!';
        document.getElementById('timerRing').style.stroke = 'var(--success)';
        document.getElementById('timerDot').style.fill = 'var(--success)';
        playSound(document.getElementById('timerSound').value);
      }
    }, 1000);
  } else {
    running = false; clearInterval(iv);
    document.getElementById('timerStartBtn').textContent = 'Resume';
    document.getElementById('timerStatus').textContent = 'Paused';
  }
}

function resetTimer() {
  running = false; clearInterval(iv);
  remaining = 0; total = 0;
  document.getElementById('timerStartBtn').textContent = 'Start';
  document.getElementById('timerStatus').textContent = 'Ready';
  document.getElementById('timerDisplay').textContent = '00:00';
  document.getElementById('timerDisplay').style.color = 'var(--text)';
  document.getElementById('timerRing').style.strokeDashoffset = 0;
  document.getElementById('timerRing').style.stroke = 'var(--accent)';
  document.getElementById('timerDot').style.fill = 'var(--accent)';
  document.getElementById('timerDot').setAttribute('cx','110');
  document.getElementById('timerDot').setAttribute('cy','14');
}

// Tab title countdown
function updateTabTitle() {
  if (running && remaining > 0) {
    document.title = fmt(remaining) + ' – Timerrapp';
  } else {
    document.title = 'Online Timer — Free Countdown Timer | Timerrapp';
  }
}

// Patch toggleTimer to also update tab
const _origToggle = toggleTimer;
toggleTimer = function() {
  _origToggle();
  updateTabTitle();
}

// Update tab every second
setInterval(updateTabTitle, 1000);

// Keyboard shortcut — Space to Start/Pause
document.addEventListener('keydown', function(e) {
  if (e.code !== 'Space') return;
  const tag = document.activeElement.tagName.toLowerCase();
  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
  e.preventDefault();
  toggleTimer();
});
</script>