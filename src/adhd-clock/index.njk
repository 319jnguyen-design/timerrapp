---
layout: base.njk
title: "ADHD Clock — Time Made Visible | Timerrapp"
description: "A calm, visual clock designed for ADHD brains. See your day in named zones, get gentle transition warnings, and use a visual focus timer with no distractions."
activePage: adhd
---

<style>
.adhd-wrap {
  max-width: 520px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 16px;
  text-align: left;
}

.adhd-card {
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 20px;
  padding: 1.5rem;
  position: relative;
  transition: border-color 0.3s;
}
[data-theme="kawaii"] .adhd-card {
  background: rgba(255,255,255,0.82);
  border: 2.5px solid #000;
  box-shadow: 3px 3px 0px #000;
}

/* Ring */
.ring-wrap { display: flex; align-items: center; justify-content: center; position: relative; margin-bottom: 1rem; }
.ring-svg { transform: rotate(-90deg); }
.ring-bg { fill: none; stroke: var(--surface2); stroke-width: 14; }
.ring-arc { fill: none; stroke-width: 14; stroke-linecap: round; transition: stroke-dashoffset 1s linear, stroke 0.8s ease; }
.ring-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; pointer-events: none; }
.ring-time { font-family: var(--font-mono); font-size: 2rem; font-weight: 300; letter-spacing: -0.02em; line-height: 1; color: var(--text); }
.ring-ampm { font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent); margin-top: 2px; }
.ring-date { font-size: 0.72rem; color: var(--muted); font-family: var(--font-body); margin-top: 4px; }

/* Zone badge */
.zone-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 5px 14px; border-radius: 100px;
  font-size: 0.82rem; font-weight: 600; font-family: var(--font-body);
  border: 2px solid currentColor; margin-bottom: 0.75rem;
  letter-spacing: 0.04em;
}

/* Anchor panel */
.anchor-panel { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.anchor-item { background: var(--surface2); border-radius: 12px; padding: 10px 14px; }
[data-theme="kawaii"] .anchor-item { background: rgba(255,255,255,0.6); border: 1.5px solid rgba(0,0,0,0.1); }
.anchor-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--hint); font-family: var(--font-body); margin-bottom: 4px; }
.anchor-value { font-size: 0.92rem; font-weight: 600; color: var(--text); font-family: var(--font-body); }
.anchor-sub { font-size: 0.75rem; color: var(--muted); font-family: var(--font-body); margin-top: 2px; }

/* Focus timer */
.focus-ring-wrap { display: flex; align-items: center; justify-content: center; position: relative; margin: 0.5rem 0; }
.focus-arc { fill: none; stroke-width: 10; stroke-linecap: round; transition: stroke-dashoffset 1s linear, stroke 0.5s ease; }
.focus-bg-arc { fill: none; stroke: var(--surface2); stroke-width: 10; }
.focus-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
.focus-display { font-family: var(--font-mono); font-size: 2.4rem; font-weight: 300; letter-spacing: -0.02em; line-height: 1; transition: color 0.5s; }
.focus-status { font-size: 0.72rem; color: var(--muted); font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }

.focus-presets { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-bottom: 0.75rem; }
.preset-btn {
  padding: 5px 14px; border-radius: 100px;
  border: 1px solid var(--border2); background: transparent;
  color: var(--muted); font-size: 0.8rem; cursor: pointer;
  font-family: var(--font-body); transition: all 0.15s;
}
.preset-btn:hover, .preset-btn.sel { border-color: var(--accent); color: var(--accent); background: rgba(200,169,110,0.08); }
[data-theme="kawaii"] .preset-btn { border: 2px solid #000; color: #000; font-weight: 700; background: rgba(255,255,255,0.5); border-radius: 8px; }
[data-theme="kawaii"] .preset-btn:hover, [data-theme="kawaii"] .preset-btn.sel { background: var(--accent); color: #000; }

.focus-controls { display: flex; gap: 8px; justify-content: center; }
.fc-btn {
  flex: 1; padding: 10px; border-radius: 12px;
  font-family: var(--font-body); font-size: 0.9rem; font-weight: 600;
  cursor: pointer; border: 1px solid var(--border2);
  background: var(--surface2); color: var(--text);
  transition: all 0.15s; max-width: 120px;
}
.fc-btn:hover { border-color: var(--accent); }
.fc-btn.primary { background: var(--accent); color: #0a0a0f; border-color: transparent; }
.fc-btn.primary:hover { opacity: 0.88; }
[data-theme="kawaii"] .fc-btn { border: 2.5px solid #000; box-shadow: 2px 2px 0px #000; font-weight: 800; }
[data-theme="kawaii"] .fc-btn.primary { background: var(--accent); color: #000; }
[data-theme="kawaii"] .fc-btn:hover { transform: translate(-1px,-1px); box-shadow: 3px 3px 0px #000; }

/* Settings */
.settings-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); }
.settings-row:last-child { border-bottom: none; }
.settings-label { font-size: 0.88rem; color: var(--text); font-family: var(--font-body); }
.settings-sub { font-size: 0.72rem; color: var(--muted); margin-top: 2px; font-family: var(--font-body); }
.toggle-switch { width: 42px; height: 24px; border-radius: 100px; border: 1px solid var(--border2); background: transparent; cursor: pointer; position: relative; transition: all 0.2s; flex-shrink: 0; }
.toggle-switch.on { background: var(--accent); border-color: var(--accent); }
.toggle-dot { position: absolute; top: 3px; left: 3px; width: 16px; height: 16px; border-radius: 50%; background: var(--muted); transition: all 0.2s; }
.toggle-switch.on .toggle-dot { transform: translateX(18px); background: #0a0a0f; }
[data-theme="kawaii"] .toggle-switch.on .toggle-dot { background: #fff; }
.warn-slider { width: 110px; accent-color: var(--accent); cursor: pointer; }

/* Toast — truly hidden until .show applied */
.adhd-toast {
  position: fixed;
  bottom: 2rem; left: 50%;
  transform: translateX(-50%);
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 16px;
  padding: 1rem 1.5rem;
  max-width: 320px; width: 90%;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  z-index: 500;
  text-align: center;
  opacity: 0;
  pointer-events: none;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.adhd-toast.show { opacity: 1; pointer-events: auto; visibility: visible; }
[data-theme="kawaii"] .adhd-toast { border: 2.5px solid #000; box-shadow: 4px 4px 0px #000; background: rgba(255,255,255,0.97); }
.toast-msg { font-size: 0.9rem; color: var(--text); font-family: var(--font-body); line-height: 1.5; }
.toast-close { margin-top: 10px; padding: 5px 16px; border-radius: 100px; border: 1px solid var(--border2); background: transparent; color: var(--muted); font-size: 0.8rem; cursor: pointer; font-family: var(--font-body); transition: all 0.15s; }
.toast-close:hover { border-color: var(--accent); color: var(--accent); }

/* Breathing overlay */
.breathing-overlay { display: none; position: fixed; inset: 0; z-index: 600; background: rgba(10,10,15,0.93); align-items: center; justify-content: center; flex-direction: column; gap: 1.5rem; text-align: center; }
[data-theme="kawaii"] .breathing-overlay { background: rgba(232,224,245,0.97); }
.breathing-overlay.show { display: flex; }
.breath-circle { width: 120px; height: 120px; border-radius: 50%; background: rgba(200,169,110,0.15); border: 2px solid var(--accent); display: flex; align-items: center; justify-content: center; transition: transform 4s ease-in-out, background 4s ease-in-out; }
.breath-circle.expand { transform: scale(1.65); background: rgba(200,169,110,0.3); }
.breath-circle.hold { transform: scale(1.65); background: rgba(200,169,110,0.45); }
.breath-circle.shrink { transform: scale(1); background: rgba(200,169,110,0.08); }
.breath-instruction { font-family: var(--font-heading); font-size: 1.8rem; color: var(--text); }
[data-theme="kawaii"] .breath-instruction { font-weight: 800; color: #1a1a2e; }
.breath-count { font-family: var(--font-mono); font-size: 3rem; font-weight: 300; color: var(--accent); }
.breath-sub { font-size: 0.85rem; color: var(--muted); font-family: var(--font-body); }
.breath-stop { padding: 8px 24px; border-radius: 100px; border: 1px solid var(--border2); background: transparent; color: var(--muted); font-size: 0.85rem; cursor: pointer; font-family: var(--font-body); margin-top: 0.5rem; transition: all 0.15s; }
.breath-stop:hover { border-color: var(--accent); color: var(--accent); }

/* Soft action buttons */
.soft-btn {
  width: 100%; padding: 13px; border-radius: 14px;
  border: 1px solid var(--border2); background: transparent;
  color: var(--muted); font-family: var(--font-body); font-size: 0.88rem;
  cursor: pointer; transition: all 0.2s; text-align: center;
}
.soft-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(200,169,110,0.04); }
[data-theme="kawaii"] .soft-btn { border: 2px solid rgba(0,0,0,0.2); color: var(--muted); background: rgba(255,255,255,0.4); }
[data-theme="kawaii"] .soft-btn:hover { border-color: var(--accent); color: var(--accent); }

/* Reorient panel */
.reorient-panel { display: none; background: var(--surface2); border-radius: 12px; padding: 1.1rem 1.25rem; margin-top: 10px; border-left: 3px solid var(--accent); text-align: left; }
.reorient-panel.show { display: block; }
.reorient-panel p { font-size: 0.88rem; color: var(--text); font-family: var(--font-body); line-height: 1.65; }

/* Pulse */
@keyframes gentlePulse { 0%,100% { box-shadow: 0 0 0 0 rgba(200,169,110,0); } 50% { box-shadow: 0 0 0 8px rgba(200,169,110,0.1); } }
.pulse-on { animation: gentlePulse 3.5s ease-in-out infinite; }
</style>

<div style="text-align:center;margin-bottom:1.5rem;">
  <h1 class="page-title" style="margin-bottom:0.3rem;">ADHD Clock</h1>
  <p class="page-subtitle" style="margin-bottom:0;">Time made visible, calm, and structured.</p>
</div>

<div class="adhd-wrap">

  <!-- 1. DAY RING + ZONE ANCHOR -->
  <div class="adhd-card" id="zoneCard">
    <div class="zone-badge" id="zoneBadge" style="color:#6366f1;border-color:#6366f133;background:#6366f111;">Loading…</div>
    <div style="font-size:0.82rem;color:var(--muted);font-family:var(--font-body);margin-bottom:1rem;" id="zoneDesc">Detecting your current zone…</div>

    <div class="ring-wrap">
      <svg class="ring-svg" width="200" height="200" viewBox="0 0 200 200" role="img" aria-label="Day progress ring">
        <circle class="ring-bg" cx="100" cy="100" r="82"/>
        <circle class="ring-arc" id="ringArc" cx="100" cy="100" r="82" stroke-dasharray="515.2" stroke-dashoffset="515.2" stroke="#c8a96e"/>
      </svg>
      <div class="ring-center">
        <div class="ring-time" id="ringTime">--:--</div>
        <div class="ring-ampm" id="ringAmpm">--</div>
        <div class="ring-date" id="ringDate">--</div>
      </div>
    </div>

    <div class="anchor-panel">
      <div class="anchor-item">
        <div class="anchor-label">Right now</div>
        <div class="anchor-value" id="anchorZone">--</div>
        <div class="anchor-sub" id="anchorDesc">--</div>
      </div>
      <div class="anchor-item">
        <div class="anchor-label">Coming up</div>
        <div class="anchor-value" id="anchorNext">--</div>
        <div class="anchor-sub" id="anchorMins">-- min away</div>
      </div>
    </div>

    <button class="soft-btn" style="margin-top:12px;border-style:dashed;" onclick="lostTrack()">
      I lost track of time — where am I?
    </button>
    <div class="reorient-panel" id="reorientPanel">
      <p id="reorientMsg"></p>
    </div>
  </div>

  <!-- 2. FOCUS TIMER -->
  <div class="adhd-card">
    <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--hint);margin-bottom:0.75rem;font-family:var(--font-body);">Focus Timer</div>

    <div class="focus-presets">
      <button class="preset-btn" onclick="setFocus(5,this)">5 min</button>
      <button class="preset-btn sel" onclick="setFocus(10,this)">10 min</button>
      <button class="preset-btn" onclick="setFocus(15,this)">15 min</button>
      <button class="preset-btn" onclick="setFocus(25,this)">25 min</button>
      <button class="preset-btn" onclick="setFocus(45,this)">45 min</button>
    </div>

    <div class="focus-ring-wrap">
      <svg width="160" height="160" viewBox="0 0 160 160" role="img" aria-label="Focus timer progress">
        <circle class="focus-bg-arc" cx="80" cy="80" r="68" transform="rotate(-90 80 80)"/>
        <circle class="focus-arc" id="focusArc" cx="80" cy="80" r="68"
          stroke-dasharray="427.3" stroke-dashoffset="0" stroke="#8b5cf6" transform="rotate(-90 80 80)"/>
      </svg>
      <div class="focus-center">
        <div class="focus-display" id="focusDisplay">10:00</div>
        <div class="focus-status" id="focusStatus">Ready</div>
      </div>
    </div>

    <div class="focus-controls">
      <button class="fc-btn primary" id="focusStartBtn" onclick="toggleFocus()">Start</button>
      <button class="fc-btn" onclick="resetFocus()">Reset</button>
    </div>
  </div>

  <!-- 3. BREATHING BUTTON -->
  <button class="soft-btn" style="padding:14px;" onclick="startBreathing()">
    Take a breathing pause
  </button>

  <!-- 4. SETTINGS -->
  <div class="adhd-card">
    <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--hint);margin-bottom:0.75rem;font-family:var(--font-body);">Settings</div>

    <div class="settings-row">
      <div>
        <div class="settings-label">Sound cues</div>
        <div class="settings-sub">Gentle tone on zone transition</div>
      </div>
      <div class="toggle-switch on" id="soundToggle" onclick="toggleSetting('sound')" role="switch" aria-checked="true" aria-label="Sound cues">
        <div class="toggle-dot"></div>
      </div>
    </div>

    <div class="settings-row">
      <div>
        <div class="settings-label">Pulse animation</div>
        <div class="settings-sub">Soft glow on the zone card</div>
      </div>
      <div class="toggle-switch on" id="pulseToggle" onclick="toggleSetting('pulse')" role="switch" aria-checked="true" aria-label="Pulse animation">
        <div class="toggle-dot"></div>
      </div>
    </div>

    <div class="settings-row">
      <div>
        <div class="settings-label">Warn <span id="warnLabel">5</span> min before zone ends</div>
        <div class="settings-sub">Gentle notification before transitions</div>
      </div>
      <input type="range" class="warn-slider" id="warnSlider" min="1" max="15" value="5"
        oninput="updateWarnThreshold(this.value)" aria-label="Warning threshold in minutes">
    </div>
  </div>

</div><!-- end .adhd-wrap -->

<!-- Toast — invisible until triggered -->
<div class="adhd-toast" id="adhdToast" role="alert" aria-live="polite">
  <div class="toast-msg" id="toastMsg">Zone transition coming up.</div>
  <button class="toast-close" onclick="closeToast()">Got it</button>
</div>

<!-- Breathing overlay -->
<div class="breathing-overlay" id="breathOverlay" role="dialog" aria-modal="true" aria-label="Breathing exercise">
  <div class="breath-circle" id="breathCircle">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
      <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
      <path d="M8 12h8M12 8v8"/>
    </svg>
  </div>
  <div class="breath-instruction" id="breathInstruction">Get ready</div>
  <div class="breath-count" id="breathCount">·</div>
  <div class="breath-sub" id="breathSub">Find a comfortable position</div>
  <button class="breath-stop" onclick="stopBreathing()">Stop</button>
</div>

<script>
const ZONES = [
  { name:'Night',   start:0,  end:6,  color:'#6366f1', desc:'Rest time. You don\'t have to be productive right now.' },
  { name:'Morning', start:6,  end:11, color:'#f59e0b', desc:'Ease in. Good for lighter tasks and planning.' },
  { name:'Focus',   start:11, end:16, color:'#10b981', desc:'Peak energy window. Great for deep work.' },
  { name:'Break',   start:16, end:17, color:'#ec4899', desc:'Step away. Rest your brain for a bit.' },
  { name:'Evening', start:17, end:21, color:'#8b5cf6', desc:'Wind down. Creative or social tasks fit well here.' },
];

const CIRC_RING  = 515.2;
const CIRC_FOCUS = 427.3;

// Settings from localStorage
let settings        = JSON.parse(localStorage.getItem('adhd_settings') || '{}');
let soundOn         = settings.sound !== false;
let pulseOn         = settings.pulse !== false;
let warnMins        = settings.warn  || 5;

// Focus timer state
let focusTotal   = 10 * 60;
let focusRemain  = focusTotal;
let focusRunning = false;
let focusIv      = null;

// Zone transition state
let warnFired      = {};
let currentZoneName = '';
let toastTimer     = null;

// Breathing state
let breathIv    = null;
let breathStep  = 0;
let breathCycle = 0;
const BREATH_TOTAL = 3;
const BREATH_SEQ = [
  { phase:'Breathe in',  dur:4, sub:'Through your nose',        circle:'expand' },
  { name:'Hold',         dur:4, sub:'Stay still',               circle:'hold'   },
  { phase:'Breathe out', dur:4, sub:'Slowly through your mouth',circle:'shrink' },
];
// fix missing phase key on hold
BREATH_SEQ[1].phase = 'Hold';

// ---- Helpers ----
function getZone(h) { return ZONES.find(z => z.start <= h && h < z.end) || ZONES[0]; }
function getNextZone(z) { return ZONES[(ZONES.indexOf(z) + 1) % ZONES.length]; }
function minsUntil(h, m, zone) {
  let diff = zone.end * 60 - (h * 60 + m);
  if (diff < 0) diff += 1440;
  return diff;
}
function fmt12(h, m) {
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12  = h % 12 || 12;
  return { time: String(h12).padStart(2,'0') + ':' + String(m).padStart(2,'0'), ampm };
}
function fmtFocus(s) {
  return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0');
}

// ---- Zone ring ----
function updateZone() {
  const now  = new Date();
  const h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();
  const zone = getZone(h);
  const next = getNextZone(zone);

  // Clock
  const { time, ampm } = fmt12(h, m);
  document.getElementById('ringTime').textContent = time;
  document.getElementById('ringAmpm').textContent = ampm;
  document.getElementById('ringDate').textContent =
    now.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });

  // Arc — minutes since midnight / 1440
  const pct = (h * 60 + m) / 1440;
  document.getElementById('ringArc').style.strokeDashoffset = CIRC_RING * (1 - pct);
  document.getElementById('ringArc').style.stroke = zone.color;

  // Zone badge
  const badge = document.getElementById('zoneBadge');
  badge.textContent = zone.name;
  badge.style.color = zone.color;
  badge.style.borderColor = zone.color + '44';
  badge.style.background  = zone.color + '11';
  document.getElementById('zoneDesc').textContent = zone.desc;
  document.getElementById('zoneCard').style.borderColor = zone.color + '44';

  // Anchor
  document.getElementById('anchorZone').textContent = zone.name;
  document.getElementById('anchorDesc').textContent = zone.desc;
  document.getElementById('anchorNext').textContent = next.name;
  const ml = minsUntil(h, m, zone);
  document.getElementById('anchorMins').textContent = ml + ' min away';

  // Pulse
  const card = document.getElementById('zoneCard');
  if (pulseOn) card.classList.add('pulse-on'); else card.classList.remove('pulse-on');

  // Zone change
  if (zone.name !== currentZoneName) { currentZoneName = zone.name; warnFired = {}; }

  // Transition warning (check every minute at s===0)
  if (s === 0 && ml === warnMins && !warnFired[zone.name + warnMins]) {
    warnFired[zone.name + warnMins] = true;
    showToast(zone.name + ' ends in ' + warnMins + ' min — ' + next.name + ' is next. ' + next.desc);
    if (soundOn) playTone();
  }
}

// ---- Focus timer ----
function setFocus(mins, btn) {
  resetFocus();
  focusTotal = focusRemain = mins * 60;
  document.getElementById('focusDisplay').textContent = fmtFocus(focusRemain);
  document.getElementById('focusDisplay').style.color = 'var(--text)';
  document.getElementById('focusArc').style.stroke = '#8b5cf6';
  document.getElementById('focusArc').style.strokeDashoffset = 0;
  document.getElementById('focusStatus').textContent = 'Ready';
  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('sel'));
  if (btn) btn.classList.add('sel');
}

function toggleFocus() {
  if (!focusRunning) {
    focusRunning = true;
    document.getElementById('focusStartBtn').textContent = 'Pause';
    document.getElementById('focusStatus').textContent = 'Focusing…';
    focusIv = setInterval(() => {
      focusRemain--;
      updateFocusDisplay();
      if (focusRemain <= 0) {
        clearInterval(focusIv); focusRunning = false;
        document.getElementById('focusStartBtn').textContent = 'Start';
        document.getElementById('focusStatus').textContent = 'Done — take a break.';
        showToast('Focus session complete. Take a proper break before starting another.');
        if (soundOn) playTone();
      }
    }, 1000);
  } else {
    clearInterval(focusIv); focusRunning = false;
    document.getElementById('focusStartBtn').textContent = 'Resume';
    document.getElementById('focusStatus').textContent = 'Paused';
  }
}

function resetFocus() {
  clearInterval(focusIv); focusRunning = false; focusRemain = focusTotal;
  document.getElementById('focusStartBtn').textContent = 'Start';
  document.getElementById('focusDisplay').textContent = fmtFocus(focusRemain);
  document.getElementById('focusDisplay').style.color = 'var(--text)';
  document.getElementById('focusArc').style.stroke = '#8b5cf6';
  document.getElementById('focusArc').style.strokeDashoffset = 0;
  document.getElementById('focusStatus').textContent = 'Ready';
  if (!focusRunning) document.title = 'ADHD Clock — Time Made Visible | Timerrapp';
}

function updateFocusDisplay() {
  const pct = focusTotal > 0 ? focusRemain / focusTotal : 0;
  const color = pct < 0.2 ? '#ef4444' : pct < 0.5 ? '#f59e0b' : '#8b5cf6';
  document.getElementById('focusArc').style.stroke = color;
  document.getElementById('focusArc').style.strokeDashoffset = CIRC_FOCUS * (1 - pct);
  document.getElementById('focusDisplay').textContent = fmtFocus(focusRemain);
  document.getElementById('focusDisplay').style.color = pct < 0.2 ? '#ef4444' : 'var(--text)';
  if (focusRunning) document.title = fmtFocus(focusRemain) + ' — ADHD Clock | Timerrapp';
}

// ---- Settings ----
function toggleSetting(key) {
  if (key === 'sound') {
    soundOn = !soundOn;
    const el = document.getElementById('soundToggle');
    el.classList.toggle('on', soundOn); el.setAttribute('aria-checked', soundOn);
    settings.sound = soundOn;
  } else if (key === 'pulse') {
    pulseOn = !pulseOn;
    const el = document.getElementById('pulseToggle');
    el.classList.toggle('on', pulseOn); el.setAttribute('aria-checked', pulseOn);
    settings.pulse = pulseOn;
    document.getElementById('zoneCard').classList.toggle('pulse-on', pulseOn);
  }
  localStorage.setItem('adhd_settings', JSON.stringify(settings));
}

function updateWarnThreshold(val) {
  warnMins = parseInt(val);
  document.getElementById('warnLabel').textContent = val;
  settings.warn = warnMins; warnFired = {};
  localStorage.setItem('adhd_settings', JSON.stringify(settings));
}

function initSettings() {
  document.getElementById('soundToggle').classList.toggle('on', soundOn);
  document.getElementById('pulseToggle').classList.toggle('on', pulseOn);
  document.getElementById('warnSlider').value = warnMins;
  document.getElementById('warnLabel').textContent = warnMins;
}

// ---- Toast ----
function showToast(msg) {
  document.getElementById('toastMsg').textContent = msg;
  const toast = document.getElementById('adhdToast');
  toast.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(closeToast, 8000);
}
function closeToast() { document.getElementById('adhdToast').classList.remove('show'); }

// ---- Lost track ----
function lostTrack() {
  const now = new Date();
  const h = now.getHours(), m = now.getMinutes();
  const zone = getZone(h);
  const next = getNextZone(zone);
  const ml = minsUntil(h, m, zone);
  const { time, ampm } = fmt12(h, m);
  const msgs = [
    `No worries — it's ${time} ${ampm}. You're in ${zone.name} time. ${zone.desc} ${next.name} is ${ml} minutes away.`,
    `All good. The clock says ${time} ${ampm}. You're in your ${zone.name} zone — ${zone.desc.toLowerCase()} ${next.name} begins in about ${ml} minutes.`,
    `That's okay. Right now it's ${time} ${ampm}. ${zone.name} zone: ${zone.desc} ${next.name} is up in ${ml} min.`,
  ];
  document.getElementById('reorientMsg').textContent = msgs[Math.floor(Math.random() * msgs.length)];
  const panel = document.getElementById('reorientPanel');
  panel.classList.add('show');
  setTimeout(() => panel.classList.remove('show'), 12000);
}

// ---- Breathing ----
function startBreathing() {
  breathStep = 0; breathCycle = 0;
  document.getElementById('breathOverlay').classList.add('show');
  document.body.style.overflow = 'hidden';
  runBreathStep();
}
function runBreathStep() {
  const phase = BREATH_SEQ[breathStep % 3];
  document.getElementById('breathInstruction').textContent = phase.phase;
  document.getElementById('breathSub').textContent = phase.sub;
  const circle = document.getElementById('breathCircle');
  circle.className = 'breath-circle';
  void circle.offsetWidth; // reflow
  circle.classList.add(phase.circle);
  let cd = phase.dur;
  document.getElementById('breathCount').textContent = cd;
  breathIv = setInterval(() => {
    cd--;
    document.getElementById('breathCount').textContent = cd || '·';
    if (cd <= 0) {
      clearInterval(breathIv);
      breathStep++;
      if (breathStep % 3 === 0) breathCycle++;
      if (breathCycle >= BREATH_TOTAL) {
        stopBreathing();
        showToast('Breathing complete. Take a moment before diving back in.');
      } else { runBreathStep(); }
    }
  }, 1000);
}
function stopBreathing() {
  clearInterval(breathIv);
  document.getElementById('breathOverlay').classList.remove('show');
  document.getElementById('breathCircle').className = 'breath-circle';
  document.body.style.overflow = '';
}

// ---- Gentle tone ----
function playTone() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [523, 659, 784].forEach((freq, i) => {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.type = 'sine'; o.frequency.value = freq;
      const t = ctx.currentTime + i * 0.22;
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.1, t + 0.08);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.7);
      o.start(t); o.stop(t + 0.8);
    });
  } catch(e) {}
}

// ---- Boot ----
initSettings();
updateZone();
setInterval(updateZone, 1000);
</script>
