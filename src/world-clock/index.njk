---
layout: base.njk
title: 'World Clock — Current Time Around the World | Timerrapp'
description: 'See the current time in cities around the world. Free online world clock showing live times for New York, London, Tokyo, Sydney and more.'
activePage: worldclock
---

<style>
  main { max-width: 850px; }
  @media (max-width: 900px) { #clockGrid { grid-template-columns: repeat(3,1fr) !important; } }
  @media (max-width: 600px) { #clockGrid { grid-template-columns: repeat(2,1fr) !important; } }
  @media (max-width: 380px) { #clockGrid { grid-template-columns: 1fr !important; } }
</style>

<h1 class="page-title">World Clock</h1>
<p class="page-subtitle">Current local time around the world.</p>

<div style="padding:1.25rem;margin-bottom:2rem;text-align:center;">
  <div style="font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem;font-family:var(--font-body);">Your local time</div>
  <div style="font-family:var(--font-mono);font-size:clamp(2rem,6vw,3.5rem);font-weight:300;letter-spacing:-0.02em;" id="localTime">--:--:--</div>
  <div style="font-family:var(--font-mono);font-size:1rem;color:var(--accent);margin-top:0.25rem;" id="localAmPm">--</div>
  <div style="margin-top:0.75rem;display:flex;align-items:center;justify-content:center;gap:8px;">
    <span style="font-size:0.75rem;color:var(--muted);">12h</span>
    <div id="militaryToggle" onclick="toggleMilitary()" style="width:40px;height:22px;border-radius:100px;border:1px solid var(--border2);background:transparent;cursor:pointer;position:relative;transition:all 0.2s;">
      <div id="militaryDot" style="position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:var(--muted);transition:all 0.2s;"></div>
    </div>
    <span style="font-size:0.75rem;color:var(--muted);">24h</span>
  </div>
  <div style="font-size:0.8rem;color:var(--muted);margin-top:0.75rem;font-family:var(--font-body);" id="localDate">--</div>
  <div style="font-size:0.75rem;color:var(--hint);margin-top:0.25rem;font-family:var(--font-body);" id="localTZ">--</div>
</div>

<div style="display:flex;gap:10px;justify-content:center;margin-bottom:1.5rem;flex-wrap:wrap;">
  <select id="citySelect" class="sound-select" style="padding:8px 14px;font-size:0.9rem;">
    <option value="">— Add a city —</option>
    <option value="Pacific/Honolulu">Honolulu, HI</option>
    <option value="America/Anchorage">Anchorage, AK</option>
    <option value="America/Los_Angeles">Los Angeles, CA</option>
    <option value="America/Phoenix">Phoenix, AZ</option>
    <option value="America/Denver">Denver, CO</option>
    <option value="America/Chicago">Chicago, IL</option>
    <option value="America/New_York">New York, NY</option>
    <option value="America/Sao_Paulo">São Paulo, Brazil</option>
    <option value="America/Argentina/Buenos_Aires">Buenos Aires, Argentina</option>
    <option value="Europe/London">London, UK</option>
    <option value="Europe/Paris">Paris, France</option>
    <option value="Europe/Berlin">Berlin, Germany</option>
    <option value="Europe/Moscow">Moscow, Russia</option>
    <option value="Africa/Cairo">Cairo, Egypt</option>
    <option value="Africa/Nairobi">Nairobi, Kenya</option>
    <option value="Africa/Johannesburg">Johannesburg, South Africa</option>
    <option value="Asia/Dubai">Dubai, UAE</option>
    <option value="Asia/Kolkata">Mumbai, India</option>
    <option value="Asia/Dhaka">Dhaka, Bangladesh</option>
    <option value="Asia/Bangkok">Bangkok, Thailand</option>
    <option value="Asia/Ho_Chi_Minh">Ho Chi Minh City, Vietnam</option>
    <option value="Asia/Singapore">Singapore</option>
    <option value="Asia/Manila">Manila, Philippines</option>
    <option value="Asia/Shanghai">Beijing, China</option>
    <option value="Asia/Tokyo">Tokyo, Japan</option>
    <option value="Asia/Seoul">Seoul, South Korea</option>
    <option value="Australia/Sydney">Sydney, Australia</option>
    <option value="Pacific/Auckland">Auckland, New Zealand</option>
  </select>
  <button class="btn btn-primary" onclick="addCity()" style="padding:8px 20px;font-size:0.9rem;">Add</button>
</div>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;" id="clockGrid"></div>

<script>
const DEFAULT_CITIES = [
  {name:'New York, NY',tz:'America/New_York'},{name:'Chicago, IL',tz:'America/Chicago'},
  {name:'Denver, CO',tz:'America/Denver'},{name:'Los Angeles, CA',tz:'America/Los_Angeles'},
  {name:'Phoenix, AZ',tz:'America/Phoenix'},{name:'Anchorage, AK',tz:'America/Anchorage'},
  {name:'Honolulu, HI',tz:'Pacific/Honolulu'},{name:'London, UK',tz:'Europe/London'},
  {name:'Berlin, Germany',tz:'Europe/Berlin'},{name:'Dubai, UAE',tz:'Asia/Dubai'},
  {name:'Manila, Philippines',tz:'Asia/Manila'},{name:'Singapore',tz:'Asia/Singapore'},
  {name:'Ho Chi Minh City',tz:'Asia/Ho_Chi_Minh'},{name:'Tokyo, Japan',tz:'Asia/Tokyo'},
  {name:'Beijing, China',tz:'Asia/Shanghai'},{name:'Sydney, Australia',tz:'Australia/Sydney'}
];
const TZ_LABELS = {
  'Pacific/Honolulu':'Honolulu, HI','America/Anchorage':'Anchorage, AK','America/Los_Angeles':'Los Angeles, CA',
  'America/Phoenix':'Phoenix, AZ','America/Denver':'Denver, CO','America/Chicago':'Chicago, IL',
  'America/New_York':'New York, NY','America/Sao_Paulo':'São Paulo, Brazil',
  'America/Argentina/Buenos_Aires':'Buenos Aires, Argentina','Europe/London':'London, UK',
  'Europe/Paris':'Paris, France','Europe/Berlin':'Berlin, Germany','Europe/Moscow':'Moscow, Russia',
  'Africa/Cairo':'Cairo, Egypt','Africa/Nairobi':'Nairobi, Kenya','Africa/Johannesburg':'Johannesburg, South Africa',
  'Asia/Dubai':'Dubai, UAE','Asia/Kolkata':'Mumbai, India','Asia/Dhaka':'Dhaka, Bangladesh',
  'Asia/Bangkok':'Bangkok, Thailand','Asia/Ho_Chi_Minh':'Ho Chi Minh City, Vietnam','Asia/Singapore':'Singapore',
  'Asia/Manila':'Manila, Philippines','Asia/Shanghai':'Beijing, China','Asia/Tokyo':'Tokyo, Japan',
  'Asia/Seoul':'Seoul, South Korea','Australia/Sydney':'Sydney, Australia','Pacific/Auckland':'Auckland, New Zealand'
};

let cities = JSON.parse(localStorage.getItem('wc_cities')||'null') || [...DEFAULT_CITIES];
let customOrder = JSON.parse(localStorage.getItem('wc_order')||'[]');
let pinned = JSON.parse(localStorage.getItem('wc_pinned')||'[]');
let userTZ = Intl.DateTimeFormat().resolvedOptions().timeZone;
let military = localStorage.getItem('clock_military') === 'true';

function saveCities() { localStorage.setItem('wc_cities',JSON.stringify(cities)); }

function addCity() {
  const sel = document.getElementById('citySelect');
  const tz = sel.value;
  if (!tz) return;
  const name = TZ_LABELS[tz]||tz;
  if (cities.find(c=>c.tz===tz)) { sel.value=''; return; }
  cities.push({name,tz}); saveCities(); sel.value='';
  renderGrid(); initDragAndDrop();
}

function removeCity(tz) { cities=cities.filter(c=>c.tz!==tz); saveCities(); renderGrid(); initDragAndDrop(); }

function toggleMilitary() {
  military = !military;
  localStorage.setItem('clock_military',military);
  const toggle = document.getElementById('militaryToggle');
  const dot = document.getElementById('militaryDot');
  toggle.style.background = military?'var(--accent)':'transparent';
  toggle.style.borderColor = military?'var(--accent)':'var(--border2)';
  dot.style.transform = military?'translateX(18px)':'translateX(0)';
  dot.style.background = military?'#0a0a0f':'var(--muted)';
  updateLocalTime(); renderGrid(); initDragAndDrop();
}

function initMilitaryToggle() {
  if (!military) return;
  document.getElementById('militaryToggle').style.background = 'var(--accent)';
  document.getElementById('militaryToggle').style.borderColor = 'var(--accent)';
  document.getElementById('militaryDot').style.transform = 'translateX(18px)';
  document.getElementById('militaryDot').style.background = '#0a0a0f';
}

function togglePin(name) {
  pinned = pinned.includes(name)?pinned.filter(p=>p!==name):[...pinned,name];
  localStorage.setItem('wc_pinned',JSON.stringify(pinned));
  renderGrid(); initDragAndDrop();
}

function getTime(tz) {
  const now = new Date();
  if (military) {
    const parts = new Intl.DateTimeFormat('en-GB',{timeZone:tz,hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}).formatToParts(now);
    const get = t => parts.find(p=>p.type===t)?.value||'';
    return {h:get('hour'),m:get('minute'),s:get('second'),ampm:''};
  } else {
    const parts = new Intl.DateTimeFormat('en-US',{timeZone:tz,hour:'numeric',minute:'2-digit',second:'2-digit',hour12:true}).formatToParts(now);
    const get = t => parts.find(p=>p.type===t)?.value||'';
    return {h:get('hour'),m:get('minute'),s:get('second'),ampm:get('dayPeriod')};
  }
}

function getDate(tz) { return new Intl.DateTimeFormat('en-US',{timeZone:tz,weekday:'short',month:'short',day:'numeric'}).format(new Date()); }

function getOffset(tz) {
  const local = new Date(new Date().toLocaleString('en-US',{timeZone:userTZ}));
  const target = new Date(new Date().toLocaleString('en-US',{timeZone:tz}));
  const diff = Math.round((target-local)/60000);
  if (diff===0) return 'Your timezone';
  const sign=diff>0?'+':'-', h=Math.floor(Math.abs(diff)/60), m=Math.abs(diff)%60;
  return m>0?`${sign}${h}h ${m}m`:`${sign}${h}h`;
}

function isDaytime(tz) {
  const h = parseInt(new Intl.DateTimeFormat('en-US',{timeZone:tz,hour:'numeric',hour12:false}).format(new Date()));
  return h>=6&&h<20;
}

function applyOrder(list) {
  if (!customOrder.length) return list;
  const ordered = [];
  customOrder.forEach(name => { const c=list.find(x=>x.name===name); if(c) ordered.push(c); });
  list.forEach(c => { if(!ordered.find(x=>x.name===c.name)) ordered.push(c); });
  return ordered;
}

function saveOrder() {
  customOrder = Array.from(document.querySelectorAll('#clockGrid .glass')).map(c=>c.dataset.city);
  localStorage.setItem('wc_order',JSON.stringify(customOrder));
}

function renderGrid() {
  const grid = document.getElementById('clockGrid');
  let list = applyOrder([...cities]);
  list.sort((a,b)=>(pinned.includes(a.name)?0:1)-(pinned.includes(b.name)?0:1));
  const isKawaii = document.documentElement.getAttribute('data-theme') === 'kawaii';
  const isStyle3 = document.documentElement.getAttribute('data-theme') === 'style3';
  grid.innerHTML = list.map(city => {
    const t=getTime(city.tz), date=getDate(city.tz), offset=getOffset(city.tz);
    const isUser=city.tz===userTZ, isPinned=pinned.includes(city.name), day=isDaytime(city.tz);
    const cardBg = isKawaii ? 'background:rgba(255,255,255,0.9);' : isStyle3 ? 'background:rgba(0,0,0,0.32);color:#f0ede8;' : '';
    return `
    <div class="glass" style="padding:1.1rem 0.9rem;text-align:center;position:relative;cursor:grab;${cardBg}" draggable="true" data-city="${city.name}" id="card-${city.tz.replace(/\//g,'_')}">
      <div style="position:absolute;top:8px;left:8px;opacity:0.2;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="5" r="2"/><circle cx="15" cy="5" r="2"/><circle cx="9" cy="12" r="2"/><circle cx="15" cy="12" r="2"/><circle cx="9" cy="19" r="2"/><circle cx="15" cy="19" r="2"/></svg>
      </div>
      <div style="position:absolute;top:8px;right:28px;cursor:pointer;opacity:${isPinned?1:0.3};" onclick="togglePin('${city.name}')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="${isPinned?'var(--accent)':'none'}" stroke="${isPinned?'var(--accent)':'currentColor'}" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <div style="position:absolute;top:8px;right:8px;cursor:pointer;opacity:0.3;transition:opacity 0.2s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.3" onclick="removeCity('${city.tz}')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </div>
      <div style="font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;font-family:var(--font-body);">${day?'Day':'Night'}</div>
      <div style="font-weight:700;color:var(--text);font-size:0.82rem;margin-bottom:2px;line-height:1.3;font-family:var(--font-body);">${city.name}</div>
      ${isUser?`<div style="font-size:0.6rem;color:var(--accent);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px;font-family:var(--font-body);">Your location</div>`:`<div style="font-size:0.68rem;color:var(--muted);margin-bottom:4px;font-family:var(--font-body);">${offset}</div>`}
      <div style="font-family:var(--font-mono);font-size:1.3rem;font-weight:300;color:var(--text);" id="time-${city.tz.replace(/\//g,'_')}">${t.h}:${t.m}:${t.s}</div>
      <div style="font-size:0.7rem;color:var(--accent);font-family:var(--font-mono);margin-top:1px;">${t.ampm}</div>
      <div style="font-size:0.68rem;color:var(--muted);margin-top:4px;font-family:var(--font-body);">${date}</div>
    </div>`;
  }).join('');
}

function updateTimes() {
  cities.forEach(city => {
    const el = document.getElementById('time-'+city.tz.replace(/\//g,'_'));
    if (el) { const t=getTime(city.tz); el.textContent=`${t.h}:${t.m}:${t.s}`; }
  });
  updateLocalTime();
}

function initDragAndDrop() {
  const grid = document.getElementById('clockGrid');
  let dragSrc = null;
  grid.addEventListener('dragstart', e => { dragSrc=e.target.closest('.glass'); if(dragSrc) dragSrc.style.opacity='0.4'; e.dataTransfer.effectAllowed='move'; });
  grid.addEventListener('dragend', e => { const c=e.target.closest('.glass'); if(c) c.style.opacity='1'; saveOrder(); });
  grid.addEventListener('dragover', e => {
    e.preventDefault();
    const target=e.target.closest('.glass');
    if(!target||target===dragSrc) return;
    const mid=target.getBoundingClientRect().left+target.getBoundingClientRect().width/2;
    grid.insertBefore(dragSrc, e.clientX<mid?target:target.nextSibling);
  });
  let touchDrag=null, touchClone=null;
  grid.addEventListener('touchstart', e => {
    const card=e.target.closest('.glass'); if(!card) return;
    touchDrag=card;
    const rect=card.getBoundingClientRect();
    touchClone=card.cloneNode(true);
    Object.assign(touchClone.style,{position:'fixed',width:rect.width+'px',opacity:'0.8',pointerEvents:'none',zIndex:'9999',top:rect.top+'px',left:rect.left+'px'});
    document.body.appendChild(touchClone); card.style.opacity='0.3';
  },{passive:true});
  grid.addEventListener('touchmove', e => {
    if(!touchDrag||!touchClone) return; e.preventDefault();
    const touch=e.touches[0];
    touchClone.style.top=touch.clientY-touchClone.offsetHeight/2+'px';
    touchClone.style.left=touch.clientX-touchClone.offsetWidth/2+'px';
    const el=document.elementFromPoint(touch.clientX,touch.clientY);
    const target=el?.closest('.glass');
    if(target&&target!==touchDrag) { const rect=target.getBoundingClientRect(); grid.insertBefore(touchDrag,touch.clientX<rect.left+rect.width/2?target:target.nextSibling); }
  },{passive:false});
  grid.addEventListener('touchend', () => {
    if(touchDrag){touchDrag.style.opacity='1';touchDrag=null;}
    if(touchClone){touchClone.remove();touchClone=null;}
    saveOrder();
  });
}

function updateLocalTime() {
  const now = new Date();
  const h=now.getHours(), m=now.getMinutes(), s=now.getSeconds();
  let display, ampm;
  if (military) {
    display = String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0'); ampm='';
  } else {
    const ampmVal=h>=12?'PM':'AM', h12=h%12||12;
    display = String(h12).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0'); ampm=ampmVal;
  }
  document.getElementById('localTime').textContent = display;
  document.getElementById('localAmPm').textContent = ampm;
  const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('localDate').textContent = days[now.getDay()]+', '+months[now.getMonth()]+' '+now.getDate()+', '+now.getFullYear();
  document.getElementById('localTZ').textContent = userTZ;
}

initMilitaryToggle();
renderGrid();
updateLocalTime();
setInterval(updateTimes, 1000);
setInterval(updateLocalTime, 1000);
initDragAndDrop();
</script>
